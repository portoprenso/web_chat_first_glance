NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/chat_app?schema=public
# Use http://localhost:8080 when running behind the Docker nginx proxy.
FRONTEND_ORIGIN=http://localhost:5173
JWT_ACCESS_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=14
REFRESH_COOKIE_NAME=chat_refresh_token
STORAGE_DIR=./storage-data
MAX_UPLOAD_BYTES=10485760
SWAGGER_ENABLED=true
